{
  "name": "@telebid/load",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "experiment": "node --import tsx src/architecture.ts",
    "research:pilot": "node --import tsx src/index.ts --profile pilot",
    "research:quick": "node --import tsx src/index.ts --profile quick",
    "experiment:transport": "node --import tsx src/index.ts --profile quick",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/*.spec.ts"
  },
  "dependencies": {
    "eventsource": "^4.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
